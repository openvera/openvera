{
  "name": "openvera-frontend",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "knip": "knip",
    "precommit": "npm run lint && npm run typecheck && npm run knip && npm run build"
  },
  "knip": {
    "ignoreDependencies": [
      "openvera"
    ],
    "ignoreBinaries": [
      "eslint",
      "knip",
      "tsc",
      "vite"
    ]
  },
  "dependencies": {
    "@radix-ui/themes": "^3.0.0",
    "@swedev/ui": "^0.2.0",
    "@tanstack/react-query": "^5.62.0",
    "lucide-react": "^0.469.0",
    "openvera": "0.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router": "^7.1.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "knip": "^5.86.0",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
